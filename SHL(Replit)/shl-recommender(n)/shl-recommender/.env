# Copy to .env and fill in values (or set as Hugging Face Space secrets)

# LLM provider: groq | gemini | openai | anthropic | openrouter
LLM_PROVIDER=groq

# Model name (provider-specific)
LLM_MODEL=llama-3.3-70b-versatile

# Required for chat — get a free key at https://console.groq.com
LLM_API_KEY=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

# Optional tuning
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=900
LLM_TIMEOUT_SECONDS=18.0

# App
APP_ENV=dev
LOG_LEVEL=INFO
